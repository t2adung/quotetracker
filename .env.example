GEMINI_API_KEY=

# Dán nguyên link Google Sheet (https://docs.google.com/spreadsheets/d/XXXXX/edit)
# hoặc chỉ dán riêng phần ID đều được
SHEET_ID=

GOOGLE_SERVICE_ACCOUNT_PATH=

# Để trống sẽ dùng mặc định: "Nguồn Video", "Quotes" và "Scripts"
SHEET_TAB_VIDEOS=
SHEET_TAB_QUOTES=
SHEET_TAB_SCRIPTS=

# Chỉ cần khi dùng cờ --upload-drive (index.js hoặc render-quotes.js). Service Account không có
# dung lượng lưu trữ riêng nên KHÔNG dùng để upload Drive được — phải xác thực OAuth bằng chính
# tài khoản Google của bạn (xem README mục "Upload video output lên Google Drive").
#
# GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET: tạo 1 OAuth Client ID loại "Desktop app"
# trong Google Cloud Console → APIs & Services → Credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GOOGLE_DRIVE_REFRESH_TOKEN: chạy "npm run drive:login" (1 lần) sau khi đã điền 2 biến trên, làm
# theo hướng dẫn trên terminal để lấy giá trị này
GOOGLE_DRIVE_REFRESH_TOKEN=

# Folder ID của 1 thư mục trên Drive của chính bạn (Folder ID lấy trong URL thư mục, dạng
# https://drive.google.com/drive/folders/XXXXX -> XXXXX)
GOOGLE_DRIVE_FOLDER_ID=
