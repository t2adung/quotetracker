GEMINI_API_KEY=

# Dán nguyên link Google Sheet (https://docs.google.com/spreadsheets/d/XXXXX/edit)
# hoặc chỉ dán riêng phần ID đều được
SHEET_ID=

GOOGLE_SERVICE_ACCOUNT_PATH=

# Để trống sẽ dùng mặc định: "Nguồn Video", "Quotes" và "Scripts"
SHEET_TAB_VIDEOS=
SHEET_TAB_QUOTES=
SHEET_TAB_SCRIPTS=

# Chỉ cần khi dùng cờ --upload-drive ở render-quotes.js: Folder ID của 1 thư mục Google Drive
# đã share cho email service account (quyền Editor). Lấy Folder ID trong URL thư mục, dạng
# https://drive.google.com/drive/folders/XXXXX -> XXXXX
GOOGLE_DRIVE_FOLDER_ID=
